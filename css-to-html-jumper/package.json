{
  "name": "css-to-html-jumper",
  "publisher": "yoshida55",
  "displayName": "CSS to HTML Jumper",
  "description": "CSSのセレクタからHTMLでの使用箇所にジャンプ",
  "repository": {
    "type": "git",
    "url": "https://github.com/yoshida55/css-to-html-jumper"
  },
  "version": "1.10.0",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:css",
    "onLanguage:html",
    "onLanguage:javascript",
    "onLanguage:php",
    "onUri:vscode"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cssToHtmlJumper.findUsage",
        "title": "HTMLで使用箇所を検索",
        "category": "CSS to HTML"
      },
      {
        "command": "cssToHtmlJumper.jumpToSection",
        "title": "セクションにジャンプ",
        "category": "CSS to HTML"
      },
      {
        "command": "cssToHtmlJumper.jumpToNextSection",
        "title": "次のセクションへ移動",
        "category": "CSS to HTML"
      },
      {
        "command": "cssToHtmlJumper.jumpToPrevSection",
        "title": "前のセクションへ移動",
        "category": "CSS to HTML"
      },
      {
        "command": "cssToHtmlJumper.askCopilot",
        "title": "✨ Copilotに解説を求める",
        "category": "CSS to HTML"
      },
      {
        "command": "cssToHtmlJumper.removeAllRedBorders",
        "title": "🗑️ 赤枠をすべて削除",
        "category": "CSS to HTML"
      },
      {
        "command": "cssToHtmlJumper.askClaude",
        "title": "✨ Claude AIに質問",
        "category": "CSS to HTML"
      },
      {
        "command": "cssToHtmlJumper.searchMemo",
        "title": "📝 メモ検索",
        "category": "CSS to HTML"
      },
      {
        "command": "cssToHtmlJumper.nextMemoResult",
        "title": "📝 メモ検索結果: 次へ",
        "category": "CSS to HTML"
      },
      {
        "command": "cssToHtmlJumper.prevMemoResult",
        "title": "📝 メモ検索結果: 前へ",
        "category": "CSS to HTML"
      },
      {
        "command": "cssToHtmlJumper.quiz",
        "title": "🎯 クイズ",
        "category": "CSS to HTML"
      },
      {
        "command": "cssToHtmlJumper.evaluateLastQuiz",
        "title": "📝 最後のクイズを評価",
        "category": "CSS to HTML"
      },
      {
        "command": "cssToHtmlJumper.changeQuizCategory",
        "title": "🔀 クイズのカテゴリ変更",
        "category": "CSS to HTML"
      },
      {
        "command": "cssToHtmlJumper.insertSvgFromTemp",
        "title": "📋 一時ファイルからSVG挿入",
        "category": "CSS to HTML"
      },
      {
        "command": "cssToHtmlJumper.generateOverview",
        "title": "🎇 JS Overview を自動生成",
        "category": "CSS to HTML"
      },
      {
        "command": "cssToHtmlJumper.showPhpDoc",
        "title": "📖 PHP/WP関数を調べる",
        "category": "CSS to HTML"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorLangId == css",
          "command": "cssToHtmlJumper.findUsage",
          "group": "navigation"
        },
        {
          "command": "cssToHtmlJumper.askCopilot",
          "when": "editorTextFocus",
          "group": "navigation@100"
        },
        {
          "command": "cssToHtmlJumper.askClaude",
          "when": "editorTextFocus",
          "group": "navigation@101"
        },
        {
          "command": "cssToHtmlJumper.generateOverview",
          "when": "editorLangId == javascript || editorLangId == typescript",
          "group": "navigation@102"
        }
      ],
      "explorer/context": [
        {
          "command": "cssToHtmlJumper.generateOverview",
          "when": "resourceExtname == .js || resourceExtname == .ts",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "cssToHtmlJumper.showPhpDoc",
        "key": "ctrl+shift+j",
        "when": "editorLangId == php"
      },
      {
        "command": "cssToHtmlJumper.findUsage",
        "key": "ctrl+shift+h",
        "when": "editorLangId == css"
      },
      {
        "command": "cssToHtmlJumper.jumpToSection",
        "key": "ctrl+shift+a",
        "when": "editorTextFocus"
      },
      {
        "command": "cssToHtmlJumper.jumpToNextSection",
        "key": "ctrl+down",
        "when": "editorTextFocus"
      },
      {
        "command": "cssToHtmlJumper.jumpToPrevSection",
        "key": "ctrl+up",
        "when": "editorTextFocus"
      },
      {
        "command": "cssToHtmlJumper.askCopilot",
        "key": "ctrl+shift+/",
        "when": "editorTextFocus"
      },
      {
        "command": "cssToHtmlJumper.askClaude",
        "key": "ctrl+i",
        "when": "editorTextFocus"
      },
      {
        "command": "cssToHtmlJumper.searchMemo",
        "key": "ctrl+enter",
        "when": "editorTextFocus"
      },
      {
        "command": "cssToHtmlJumper.quiz",
        "key": "ctrl+shift+7",
        "when": "editorTextFocus"
      },
      {
        "command": "cssToHtmlJumper.evaluateLastQuiz",
        "key": "ctrl+shift+8"
      },
      {
        "command": "cssToHtmlJumper.insertSvgFromTemp",
        "key": "ctrl+alt+s",
        "when": "editorTextFocus"
      },
      {
        "command": "cssToHtmlJumper.nextMemoResult",
        "key": "ctrl+shift+down",
        "when": "editorTextFocus"
      },
      {
        "command": "cssToHtmlJumper.prevMemoResult",
        "key": "ctrl+shift+up",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "CSS to HTML Jumper",
      "properties": {
        "cssToHtmlJumper.targetFiles": {
          "type": "string",
          "default": "**/*.html",
          "description": "検索対象のHTMLファイル（glob形式）。複数指定する場合はカンマ区切り。例: **/index.html, **/*.html"
        },
        "cssToHtmlJumper.copilotPrompt": {
          "type": "string",
          "default": "このコードの目的を簡潔に説明して",
          "description": "Copilot解説機能で使用するプロンプトのテンプレート。"
        },
        "cssToHtmlJumper.claudeApiKey": {
          "type": "string",
          "default": "",
          "description": "Claude API キー（sk-ant-...）"
        },
        "cssToHtmlJumper.claudeModel": {
          "type": "string",
          "enum": ["claude-opus-4-6-20260205", "claude-opus-4-5-20251124", "claude-sonnet-4-5-20250929"],
          "default": "claude-sonnet-4-5-20250929",
          "description": "使用するClaudeモデル（Opus 4.6: 最高性能 ¥5.6/回 | Opus 4.5: 高性能 ¥4.4/回 | Sonnet 4.5: バランス ¥3.4/回）"
        },
        "cssToHtmlJumper.memoFilePath": {
          "type": "string",
          "default": "",
          "description": "メモ検索機能で使用するメモファイルのフルパス。例: D:\\50_knowledge\\01_memo.md"
        },
        "cssToHtmlJumper.enableAiHover": {
          "type": "boolean",
          "default": false,
          "description": "AI Hover機能を有効にする（JS/TS/HTMLファイルを開くたびにGemini APIを呼び出します。デフォルト: 無効）"
        },
        "cssToHtmlJumper.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Gemini API キー（Fuzzy検索で結果0件時のフォールバック用）"
        },
        "cssToHtmlJumper.aiModel": {
          "type": "string",
          "enum": ["claude-sonnet-4-5", "gemini-3-flash"],
          "default": "claude-sonnet-4-5",
          "description": "Ctrl+I で使用するAIモデル（claude-sonnet-4-5: 高精度だが遅い / gemini-3-flash: 高速かつ安い）"
        },
        "cssToHtmlJumper.quizCategory": {
          "type": "string",
          "default": "全て",
          "description": "クイズ出題時のカテゴリフィルタ。「全て」またはメモ内のカテゴリ名（例: CSS, JavaScript）"
        },
        "cssToHtmlJumper.svgTempFilePath": {
          "type": "string",
          "default": "",
          "description": "SVG一時ファイルのパス。空欄なら %TEMP%\\svg_clipboard.svg を使用"
        },
        "cssToHtmlJumper.quizCategories": {
          "type": "array",
          "default": ["CSS", "JavaScript", "Python", "HTML"],
          "description": "カテゴリ判定に使用する単語リスト。見出し末尾がこのリストの単語ならカテゴリ扱い"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.0.0"
  }
}
